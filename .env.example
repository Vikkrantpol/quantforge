# QuantForge — Environment Variables
# Copy this to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8010
FRONTEND_URL=http://localhost:5173

# Optional: Alpaca Markets (US stocks)
# Get keys from: https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: Zerodha Kite Connect (Indian markets)
# Get keys from: https://kite.trade
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Optional: FYERS (Indian markets / crypto)
# Get keys from: https://myapi.fyers.in/
# Use the QuantForge callback URL for the Link Broker login flow.
# Any normal http/https URL can still be stored here for manual-token mode.
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=http://localhost:5173/broker/fyers/callback
FYERS_ACCESS_TOKEN=
